# =============================================================================
# REQUIRED — copy this file to .env.local and fill in your Supabase values
# =============================================================================
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# App URL — used for OAuth redirects
# Local:    http://localhost:3000
# Vercel:   https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# GITHUB ACTIONS ONLY — add these as GitHub repository secrets (not in Vercel)
# =============================================================================
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_PROJECT_ID=your-project-ref

# =============================================================================
# OPTIONAL — Sentry error tracking (free tier)
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# =============================================================================
# DEVELOPMENT ONLY — override today's date for streak/calendar testing
# =============================================================================
# NEXT_PUBLIC_MOCK_DATE=2026-06-15

# =============================================================================
# SUPABASE DASHBOARD CHECKLIST (do this once per environment)
# =============================================================================
# Authentication → URL Configuration:
#   Site URL:        http://localhost:3000  (or your Vercel URL)
#   Redirect URLs:   http://localhost:3000/auth/callback
#                    https://your-app.vercel.app/auth/callback
#
# Authentication → Providers:
#   ✓ Email enabled
#   ✓ Google OAuth enabled (add Client ID + Secret from Google Cloud)
#   ✓ GitHub OAuth enabled (add Client ID + Secret from GitHub)
#
# Vercel → Project → Settings → Environment Variables:
#   Add NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#   and NEXT_PUBLIC_APP_URL for Production, Preview, and Development.
