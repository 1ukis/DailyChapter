# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — GitHub Actions migrations only (never expose to client)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_PROJECT_ID=your-project-ref

# Sentry (optional in development)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Development only — override today's date for streak/calendar testing
# NEXT_PUBLIC_MOCK_DATE=2026-06-15

# App URL (used for OAuth redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
